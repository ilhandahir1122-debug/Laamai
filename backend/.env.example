# Solana RPC endpoint. The public default is rate-limited — get a free key from
# Helius (helius.dev), QuickNode, or Alchemy for production use.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Port the server listens on (Render sets this automatically — safe to leave as-is).
PORT=4000

# Comma-free single origin allowed to call this API, e.g. https://yourname.github.io
# Use * only for local testing.
ALLOWED_ORIGIN=*

# Pinata (https://pinata.cloud) — used to upload token logo + metadata JSON to IPFS.
# Leave blank to disable auto-upload; users can then paste a metadata URI manually.
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Platform fees, added as a normal SOL transfer inside the same transaction the
# user signs (the backend never touches the funds directly). Leave
# SERVICE_FEE_WALLET blank to disable both fees.
SERVICE_FEE_WALLET=3UMq1k33dCS6wzKvj5AhTeWWa1YT5AHViBBC9MUiqD53
CREATE_TOKEN_FEE_SOL=0.02
LIQUIDITY_FEE_SOL=0.014
